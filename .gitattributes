# Normalize line endings
* text=auto eol=lf

# Godot-specific
*.gd text eol=lf
*.tscn text eol=lf
*.tres text eol=lf
*.cfg text eol=lf
*.godot text eol=lf

# C#
*.cs text eol=crlf
*.csproj text eol=crlf
*.sln text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg text
*.mp3 binary
*.ogg binary
*.wav binary
*.ttf binary
*.otf binary
